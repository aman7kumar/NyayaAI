{
  "base_model":    "meta-llama/Llama-2-7b-hf",
  "train_file":    "backend/data/llm_finetune.jsonl",
  "output_dir":    "backend/models/saved/legal_llm",
  "max_length":    1024,
  "batch_size":    2,
  "grad_accum":    8,
  "epochs":        2,
  "learning_rate": 2e-4,
  "warmup_ratio":  0.05,
  "use_lora":      true,
  "lora_r":        16,
  "lora_alpha":    32,
  "lora_dropout":  0.05,
  "lora_target":   ["q_proj", "v_proj"],
  "load_in_4bit":  true,
  "save_steps":    100,
  "logging_steps": 25,
  "seed":          42
}
